{
  "name": "server-for-htmx",
  "version": "1.0.0",
  "description": "A typescript simple project created with Node Genie",
  "main": "dist/server.js",
  "type": "module",
  "packageManager": "pnpm",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "lint": "eslint *.{js,ts}",
    "lint:fix": "eslint *.{js,ts} --fix",
    "format": "prettier --write *.{js,ts}"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.14",
    "tsx": "^3.14.0",
    "rimraf": "^5.0.5",
    "eslint": "^8.52.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "prettier": "^3.0.3"
  }
}
