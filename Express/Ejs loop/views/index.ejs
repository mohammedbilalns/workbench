<%- include("header.ejs") %>

<body>
  <h1>EJS Tags</h1>

  <p>Current second: <%= seconds %></p>

  <% if(seconds %2 === 0 ){ %>
  <ul>
    <% items.forEach((fruit) => { %>

    <li><%= fruit %></li>
    <% }) %>
  </ul>
  <% } else { %>
  <p>No items to display</p>
  <% } %>

  <p><%- htmlContent %></p>
</body>

